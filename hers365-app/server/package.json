{
  "name": "server",
  "version": "1.0.0",
  "description": "HERS365 Backend",
  "main": "index.ts",
  "type": "module",
  "scripts": {
    "dev": "tsx watch index.ts",
    "dev:legacy": "tsx watch index.ts", // Legacy monolithic mode
    "dev:microservices": "tsx watch index.ts", // New microservices mode
    "start": "node dist/index.js",
    "start:microservices": "node dist/index.js",
    "build": "tsc",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx seed.ts",
    "db:migrate": "tsx scripts/migrate-microservices.ts",
    "services:health": "node scripts/check-services-health.js",
    "services:logs": "docker-compose logs -f",
    "event-store:cleanup": "tsx scripts/cleanup-event-store.ts",
    "metrics:export": "tsx scripts/export-metrics.ts",
    "tracing:setup": "tsx scripts/setup-tracing.ts",
    "test:e2e": "tsx scripts/run-e2e-tests.ts",
    "test:performance": "tsx scripts/run-performance-tests.ts",
    "test:load": "artillery run scripts/load-test.yml",
    "compliance:check": "tsx scripts/run-compliance-checks.ts",
    "compliance:report": "tsx scripts/generate-compliance-report.ts",
    "data:export": "tsx scripts/process-data-exports.ts",
    "data:delete": "tsx scripts/process-data-deletions.ts",
    "audit:verify": "tsx scripts/verify-audit-integrity.ts",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "infrastructure:init": "tsx scripts/init-azure-infrastructure.ts",
    "cosmos:setup": "tsx scripts/setup-cosmos-infrastructure.ts",
    "cosmos:migrate": "tsx scripts/migrate-to-cosmos.ts",
    "compliance:setup": "tsx scripts/setup-compliance-infrastructure.ts"
  },
  "dependencies": {
    "@azure/cosmos": "^4.0.0",
    "@azure/service-bus": "^7.9.3",
    "@azure/identity": "^4.2.1",
    "@azure/keyvault-secrets": "^4.8.0",
    "@azure/storage-blob": "^12.17.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.0.0",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.3",
    "esbuild": "^0.25.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "node-fetch": "^3.3.2",
    "openai": "^4.86.1",
    "pg": "^8.13.3",
    "stripe": "^17.7.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.1",
    "@opentelemetry/api": "^1.8.0",
    "@opentelemetry/sdk-node": "^0.52.1",
    "@opentelemetry/auto-instrumentations-node": "^0.52.1",
    "@opentelemetry/exporter-jaeger": "^1.28.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
