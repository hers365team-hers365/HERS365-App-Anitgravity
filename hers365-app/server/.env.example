# ===========================================
# H.E.R.S.365 Environment Configuration
# ===========================================

# ============ DATABASE ============
# IMPORTANT: Switch to PostgreSQL for production (50K users)
DATABASE_URL=sqlite://./database.db
# For production use: postgres://user:password@host:5432/hers365

# Connection Pool Settings (for PostgreSQL)
DB_POOL_MAX=100
DB_POOL_MIN=10

# ============ REDIS (Required for 50K scale) ============
# Uncomment for production
# REDIS_URL=redis://localhost:6379

# ============ AUTHENTICATION ============
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES=7d

# ============ PAYMENTS (Stripe) ============
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ============ AI SERVICES (OpenAI) ============
# Get key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ============ SPORTS DATA (MaxPreps) ============
# MaxPreps API - contact for access
MAXPREPS_API_KEY=your_maxpreps_key

# ============ GOOGLE AUTH ============
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============ RATE LIMITING ============
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=50

# ============ APPLICATION ============
NODE_ENV=development
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# ============ ENABLE AI AGENTS (Dev only) ============
ENABLE_AI_AGENTS=true

# ============ AZURE COSMOS DB (Primary Database) ============
# Required for high-performance data operations
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-cosmos-db-key
COSMOS_DATABASE=HERS365
COSMOS_API_PORT=4000

# ============ COMPLIANCE & DATA GOVERNANCE ============
# Enterprise-grade compliance framework
COMPLIANCE_PORT=4001
COPPA_AGE_VERIFICATION=true
COPPA_PARENTAL_CONSENT_REQUIRED=true
FERPA_DATA_RETENTION_DAYS=2555
FERPA_PARENTAL_ACCESS_ENABLED=true
GDPR_CONSENT_MANAGEMENT=true
GDPR_BREACH_NOTIFICATION_EMAIL=security@company.com
GDPR_DATA_PROTECTION_OFFICER=dpo@company.com

# ============ AZURE STORAGE (Compliance Exports) ============
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=yourkey;EndpointSuffix=core.windows.net
EXPORT_CONTAINER=compliance-exports
EXPORT_SAS_EXPIRY_HOURS=168

# ============ AUDIT LOGGING ============
AUDIT_LOG_RETENTION_DAYS=2555
AUDIT_CHAIN_VERIFICATION_ENABLED=true
AUDIT_INTEGRITY_CHECK_INTERVAL=3600000

# ============ AZURE SERVICE BUS (Event-Driven Architecture) ============
# Required for microservices communication
AZURE_SERVICEBUS_CONNECTION_STRING=Endpoint=sb://your-namespace.servicebus.windows.net/;SharedAccessKeyName=RootManageSharedAccessKey;SharedAccessKey=your-key
# Alternative: Use Azure AD authentication
# AZURE_SERVICEBUS_NAMESPACE=your-namespace
# AZURE_TENANT_ID=your-tenant-id
# AZURE_CLIENT_ID=your-client-id
# AZURE_CLIENT_SECRET=your-client-secret

# ============ AZURE KEY VAULT (Secrets Management) ============
AZURE_KEYVAULT_URI=https://your-keyvault.vault.azure.net/

# ============ DISTRIBUTED TRACING (OpenTelemetry + Jaeger) ============
JAEGER_ENDPOINT=http://localhost:14268/api/traces
SERVICE_INSTANCE_ID=dev-instance-001

# ============ SERVICE DISCOVERY ============
SERVICE_REGISTRY_URL=http://localhost:8500
SERVICE_HEALTH_CHECK_INTERVAL=30000

# ============ MICROSERVICES CONFIGURATION ============
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
RECRUITING_SERVICE_PORT=3003
PAYMENT_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
ANALYTICS_SERVICE_PORT=3006
AUDIT_SERVICE_PORT=3007

# ============ EVENT PROCESSING ============
ENABLE_EVENT_SOURCING=true
ENABLE_CQRS=true
ENABLE_SAGA_ORCHESTRATION=true
EVENT_PROCESSING_BATCH_SIZE=10
EVENT_PROCESSING_CONCURRENCY=5

# ============ COMPLIANCE SETTINGS ============
COPPA_AGE_VERIFICATION=true
COPPA_PARENTAL_CONSENT_REQUIRED=true
FERPA_DATA_RETENTION_DAYS=2555
GDPR_DATA_PROCESSING=true
GDPR_RIGHT_TO_DELETION=true

# ============ CIRCUIT BREAKER SETTINGS ============
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60000
CIRCUIT_BREAKER_MONITORING_PERIOD=60000

# ============ LOGGING ============
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_DISTRIBUTED_TRACING=true
ENABLE_METRICS_COLLECTION=true

# ============ SECURITY ============
ENCRYPTION_KEY=your-256-bit-encryption-key-for-sensitive-data
REFRESH_TOKEN_SECRET=your-refresh-token-secret-key
IDEMPOTENCY_KEY_TTL=86400000